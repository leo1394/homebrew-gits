#!/bin/bash

VERSION="0.1.0"
CONFIG_KEY="gits.sharedSubmodules"

print_cmd() {
    printf "\033[1;32m%s\033[0m\n" "$1"
}

error() {
    echo "gits: $*" >&2
    return 1
}

require_git() {
    command -v git >/dev/null 2>&1 || {
        error "Git is required. Install it with 'brew install git', then retry."
        return 1
    }
}

git_root() {
    git rev-parse --show-toplevel 2>/dev/null
}

usage() {
    cat <<'EOF'
usage:
  gits init [shared_path]          initialize submodules
                                   shared mode is enabled only when shared_path is given
  gits pull                        fast-forward the repository and update submodules
  gits reset [--hard]              reset the repository and its submodules
  gits config [shared_path|--unset]
                                   show, enable, or disable shared mode for this repository
  gits list                        show submodules and shared repository state
  gits <args...>                   pass through to git submodule <args...>
  gits --version                   show the installed version
EOF
}

shared_base() {
    local root="$1"
    git -C "$root" config --local --get "$CONFIG_KEY" 2>/dev/null
}

canonical_directory() {
    local path="$1"

    mkdir -p "$path" || return 1
    (
        cd "$path" || exit 1
        pwd -P
    )
}

enable_shared() {
    local root="$1"
    local requested_path="$2"
    local path

    path=$(canonical_directory "$requested_path") || return 1
    git -C "$root" config --local "$CONFIG_KEY" "$path" || return 1
    echo "shared repository enabled for this project: $path"
}

disable_shared() {
    local root="$1"

    git -C "$root" config --local --unset-all "$CONFIG_KEY" 2>/dev/null || true
    echo "shared repository disabled for this project"
}

submodule_entries() {
    local root="$1"
    local entry
    local key
    local path

    [ -f "$root/.gitmodules" ] || return 0
    while IFS= read -r -d '' entry; do
        key=${entry%%$'\n'*}
        path=${entry#*$'\n'}
        printf '%s\0%s\0' "$key" "$path"
    done < <(git config -z --file "$root/.gitmodules" --get-regexp 'submodule\..*\.path' 2>/dev/null)
}

normal_init() {
    local root="$1"

    print_cmd "git submodule sync --recursive"
    git -C "$root" submodule sync --recursive || return 1
    print_cmd "git submodule update --init --recursive"
    git -C "$root" submodule update --init --recursive
}

normal_pull() {
    local root="$1"

    print_cmd "git pull --ff-only"
    git -C "$root" pull --ff-only || return 1
    normal_init "$root"
}

mirror_path() {
    local base="$1"
    local url="$2"
    local hash
    local slug

    hash=$(printf '%s' "$url" | git hash-object --stdin) || return 1
    slug=$(basename "${url%.git}")
    slug=$(printf '%s' "$slug" | tr -c '[:alnum:]._- ' '_' | tr ' ' '_')
    printf '%s/repositories/%s-%s.git\n' "$base" "$slug" "${hash:0:12}"
}

update_mirror() {
    local url="$1"
    local mirror="$2"

    mkdir -p "$(dirname "$mirror")" || return 1
    if [ -e "$mirror" ]; then
        if [ "$(git -C "$mirror" rev-parse --is-bare-repository 2>/dev/null)" != "true" ]; then
            error "shared repository path is not a bare Git repository: $mirror"
            return 1
        fi
        print_cmd "git -C $mirror remote update --prune"
        git -C "$mirror" remote update --prune
    else
        print_cmd "git clone --mirror $url $mirror"
        git clone --mirror "$url" "$mirror"
    fi
}

add_alternate() {
    local checkout="$1"
    local mirror="$2"
    local alternates
    local objects="$mirror/objects"

    alternates=$(git -C "$checkout" rev-parse --path-format=absolute --git-path objects/info/alternates) || return 1
    mkdir -p "$(dirname "$alternates")" || return 1
    if ! grep -qxF "$objects" "$alternates" 2>/dev/null; then
        echo "$objects" >> "$alternates" || return 1
    fi
}

shared_update() {
    local root="$1"
    local base="$2"
    local key
    local path
    local name
    local url
    local mirror

    echo "using shared repository: $base"
    print_cmd "git submodule sync --recursive"
    git -C "$root" submodule sync --recursive || return 1

    while IFS= read -r -d '' key && IFS= read -r -d '' path; do
        [ -n "$key" ] || continue
        name=${key#submodule.}
        name=${name%.path}

        git -C "$root" submodule init -- "$path" >/dev/null || return 1
        url=$(git -C "$root" config --local --get "submodule.$name.url")
        if [ -z "$url" ]; then
            error "missing submodule URL: $path"
            return 1
        fi

        mirror=$(mirror_path "$base" "$url") || return 1
        update_mirror "$url" "$mirror" || return 1

        if git -C "$root/$path" rev-parse --git-dir >/dev/null 2>&1; then
            print_cmd "git submodule update --init -- $path"
            git -C "$root" submodule update --init -- "$path" || return 1
        else
            print_cmd "git submodule update --init --reference $mirror -- $path"
            git -C "$root" submodule update --init --reference "$mirror" -- "$path" || return 1
        fi

        print_cmd "git -C $path submodule update --init --recursive"
        git -C "$root/$path" submodule update --init --recursive || return 1
        add_alternate "$root/$path" "$mirror" || return 1
    done < <(submodule_entries "$root")
}

shared_pull() {
    local root="$1"
    local base="$2"

    print_cmd "git pull --ff-only"
    git -C "$root" pull --ff-only || return 1
    shared_update "$root" "$base"
}

reset_repository() {
    local root="$1"
    local mode="$2"

    if [ -n "$mode" ] && [ "$mode" != "--hard" ]; then
        error "reset accepts only --hard"
        return 1
    fi

    if [ "$mode" = "--hard" ]; then
        print_cmd "git reset --hard"
        git -C "$root" reset --hard || return 1
        print_cmd "git submodule foreach --recursive git reset --hard"
        git -C "$root" submodule foreach --recursive git reset --hard || return 1
        print_cmd "git submodule update --init --recursive --force"
        git -C "$root" submodule update --init --recursive --force || return 1
    else
        print_cmd "git reset"
        git -C "$root" reset || return 1
        print_cmd "git submodule foreach --recursive git reset"
        git -C "$root" submodule foreach --recursive git reset || return 1
    fi

    git -C "$root" status --short
}

list_submodules() {
    local root="$1"
    local base="$2"
    local key
    local path
    local name
    local url
    local mirror
    local state

    if [ -n "$base" ]; then
        echo "shared repository: $base"
    else
        echo "shared repository: disabled"
    fi

    if [ ! -f "$root/.gitmodules" ]; then
        echo "no submodules"
        return 0
    fi

    while IFS= read -r -d '' key && IFS= read -r -d '' path; do
        [ -n "$key" ] || continue
        if [ -n "$base" ]; then
            name=${key#submodule.}
            name=${name%.path}
            url=$(git -C "$root" config --local --get "submodule.$name.url" 2>/dev/null)
            [ -n "$url" ] || url=$(git config --file "$root/.gitmodules" --get "submodule.$name.url")
            mirror=$(mirror_path "$base" "$url") || return 1
            state="not cached"
            [ -d "$mirror" ] && state="cached"
            echo "$path -> $mirror ($state)"
        else
            echo "$path"
        fi
    done < <(submodule_entries "$root")
}

main() {
    local root
    local base

    case "$1" in
        help|--help|-h)
            usage
            return 0
            ;;
        --version|-v)
            echo "gits $VERSION"
            return 0
            ;;
    esac

    require_git || return 1
    root=$(git_root) || {
        error "not a Git repository"
        return 1
    }

    case "$1" in
        init)
            if [ -n "$3" ]; then
                error "init accepts at most one shared_path"
                return 1
            fi
            if [ -n "$2" ]; then
                enable_shared "$root" "$2" || return 1
            fi
            base=$(shared_base "$root")
            if [ -n "$base" ]; then
                shared_update "$root" "$base"
            else
                normal_init "$root"
            fi
            ;;
        pull)
            [ -z "$2" ] || {
                error "pull accepts no arguments"
                return 1
            }
            base=$(shared_base "$root")
            if [ -n "$base" ]; then
                shared_pull "$root" "$base"
            else
                normal_pull "$root"
            fi
            ;;
        reset)
            [ -z "$3" ] || {
                error "reset accepts at most one argument"
                return 1
            }
            reset_repository "$root" "$2"
            ;;
        config)
            [ -z "$3" ] || {
                error "config accepts at most one argument"
                return 1
            }
            case "$2" in
                --unset)
                    disable_shared "$root"
                    ;;
                "")
                    base=$(shared_base "$root")
                    if [ -n "$base" ]; then
                        echo "$base"
                    else
                        echo "shared repository disabled for this project"
                    fi
                    ;;
                *)
                    enable_shared "$root" "$2"
                    ;;
            esac
            ;;
        list|--list)
            [ -z "$2" ] || {
                error "list accepts no arguments"
                return 1
            }
            base=$(shared_base "$root")
            list_submodules "$root" "$base"
            ;;
        "")
            git -C "$root" submodule
            ;;
        *)
            git -C "$root" submodule "$@"
            ;;
    esac
}

main "$@"
