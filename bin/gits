#!/bin/bash

VERSION="0.2.8"
CONFIG_KEY="gits.sharedSubmodules"
CLEAN_GRACE_SECONDS=2592000
RED=$'\033[1;31m'
GREEN=$'\033[1;32m'
YELLOW=$'\033[1;33m'
RESET=$'\033[0m'
SHARED_LOCK_DIR=""

print_cmd() {
    printf '%s%s%s\n' "$GREEN" "$1" "$RESET"
}

print_red() {
    printf '%s%s%s\n' "$RED" "$1" "$RESET"
}

error() {
    printf '%s%s%s\n' "$RED" "gits: $*" "$RESET" >&2
    return 1
}

require_git() {
    command -v git >/dev/null 2>&1 || {
        error "Git is required. Install it with 'brew install git', then retry."
        return 1
    }
}

git_root() {
    git rev-parse --show-toplevel 2>/dev/null
}

usage() {
    cat <<'EOF'
usage:
  gits init [shared_path]          initialize submodules
                                   shared mode is enabled only when shared_path is given
  gits pull [<path>...|--all]      fast-forward the repository and update submodules
  gits reset [--hard] [<path>...|--all]
                                   reset the repository or selected submodules
  gits add <args...>               pass through to git submodule add
  gits admit <path...|--all>       stage changes, edit a message, and commit
  gits config [shared_path|--unset]
                                   show, enable, or disable shared mode for this repository
  gits list                        show submodules and shared modules repository state
  gits clean [--scan <root>...]    preview unused shared mirrors
  gits clean --apply               delete mirrors unused for at least 30 days
  gits clean --forget-scan <root>  remove a registered scan root
  gits <args...>                   pass through to git submodule <args...>
  gits --version                   show the installed version
EOF
}

completion_script() {
    case "$1" in
        bash)
            cat <<'EOF'
_gits_complete_paths() {
    local path_type="$1"
    local path_prefix="$2"
    local candidate

    while IFS= read -r candidate; do
        COMPREPLY+=( "$candidate" )
    done < <(compgen "$path_type" -- "$path_prefix")
}

_gits() {
    local cur prev subcommand

    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev=""
    if [ "$COMP_CWORD" -gt 0 ]; then
        prev="${COMP_WORDS[COMP_CWORD-1]}"
    fi

    if [ "$COMP_CWORD" -eq 1 ]; then
        COMPREPLY=( $(compgen -W "init pull reset add admit config list clean status update deinit foreach summary sync set-branch set-url absorbgitdirs help --help -h --version -v" -- "$cur") )
        return 0
    fi

    subcommand="${COMP_WORDS[1]}"
    case "$subcommand" in
        admit)
            if [[ "$cur" == -* ]]; then
                COMPREPLY=( $(compgen -W "--all" -- "$cur") )
            else
                _gits_complete_paths -f "$cur"
            fi
            ;;
        pull)
            if [[ "$cur" == -* ]]; then
                COMPREPLY=( $(compgen -W "--all" -- "$cur") )
            else
                _gits_complete_paths -f "$cur"
            fi
            ;;
        clean)
            case "$prev" in
                --scan|--forget-scan)
                    _gits_complete_paths -d "$cur"
                    ;;
                *)
                    if [[ "$cur" == -* ]]; then
                        COMPREPLY=( $(compgen -W "--scan --apply --forget-scan" -- "$cur") )
                    fi
                    ;;
            esac
            ;;
        reset)
            if [[ "$cur" == -* ]]; then
                COMPREPLY=( $(compgen -W "--hard --all" -- "$cur") )
            else
                _gits_complete_paths -f "$cur"
            fi
            ;;
        config)
            if [ "$prev" != "--unset" ]; then
                COMPREPLY=( $(compgen -W "--unset" -- "$cur") )
                _gits_complete_paths -d "$cur"
            fi
            ;;
        init)
            _gits_complete_paths -d "$cur"
            ;;
        add)
            case "$prev" in
                --reference)
                    _gits_complete_paths -d "$cur"
                    ;;
                -b|--branch|--name|--depth)
                    ;;
                *)
                    if [[ "$cur" == -* ]]; then
                        COMPREPLY=( $(compgen -W "-q --quiet -b --branch -f --force --name --reference --dissociate --depth --progress --no-progress --" -- "$cur") )
                    else
                        _gits_complete_paths -f "$cur"
                    fi
                    ;;
            esac
            ;;
    esac
}

complete -F _gits gits
EOF
            ;;
        zsh)
            cat <<'EOF'
#compdef gits

_gits() {
    local -a commands

    commands=(
        'init:initialize submodules'
        'pull:fast-forward the repository and update submodules'
        'reset:reset the repository and its submodules'
        'add:pass through to git submodule add'
        'admit:stage changes, edit a message, and commit'
        'config:show, enable, or disable shared mode'
        'list:show submodules and shared repository state'
        'clean:preview or remove unused shared mirrors'
        'status:pass through to git submodule status'
        'update:pass through to git submodule update'
        'deinit:pass through to git submodule deinit'
        'foreach:pass through to git submodule foreach'
        'summary:pass through to git submodule summary'
        'sync:pass through to git submodule sync'
        'set-branch:pass through to git submodule set-branch'
        'set-url:pass through to git submodule set-url'
        'absorbgitdirs:pass through to git submodule absorbgitdirs'
        'help:show help'
        '--help:show help'
        '-h:show help'
        '--version:show the installed version'
        '-v:show the installed version'
    )

    if (( CURRENT == 2 )); then
        _describe 'command' commands
        return
    fi

    case "$words[2]" in
        admit)
            _arguments '--all[stage every declared submodule]' '*:path:_files'
            ;;
        pull)
            _arguments '--all[update every declared submodule]' '*:submodule path:_files'
            ;;
        clean)
            _arguments \
                '*--scan[register a project scan root]:directory:_directories' \
                '--apply[delete mirrors unused for at least 30 days]' \
                '--forget-scan[remove a registered scan root]:directory:_directories'
            ;;
        reset)
            _arguments \
                '--hard[discard working tree changes]' \
                '--all[reset the repository and every declared submodule]' \
                '*:submodule path:_files'
            ;;
        config)
            _arguments '--unset[disable shared mode]' '1:shared directory:_directories'
            ;;
        init)
            _arguments '1:shared directory:_directories'
            ;;
        add)
            _arguments \
                '(-q --quiet)'{-q,--quiet}'[suppress progress output]' \
                '(-b --branch)'{-b,--branch}'[checkout branch]:branch:' \
                '(-f --force)'{-f,--force}'[allow an otherwise ignored path]' \
                '--name[set the submodule name]:name:' \
                '--reference[reference repository]:repository:_directories' \
                '--dissociate[borrow objects only during clone]' \
                '--depth[create a shallow clone]:depth:' \
                '--progress[force progress reporting]' \
                '--no-progress[disable progress reporting]' \
                '--[end option parsing]' \
                '1:repository:_files' \
                '2:path:_files'
            ;;
    esac
}

compdef _gits gits
EOF
            ;;
        fish)
            cat <<'EOF'
function __gits_no_subcommand
    set -l words (commandline -opc)
    test (count $words) -eq 1
end

complete -c gits -f -n __gits_no_subcommand -a init -d 'Initialize submodules'
complete -c gits -f -n __gits_no_subcommand -a pull -d 'Fast-forward the repository and update submodules'
complete -c gits -f -n __gits_no_subcommand -a reset -d 'Reset the repository and its submodules'
complete -c gits -f -n __gits_no_subcommand -a add -d 'Pass through to git submodule add'
complete -c gits -f -n __gits_no_subcommand -a admit -d 'Stage changes, edit a message, and commit'
complete -c gits -f -n __gits_no_subcommand -a config -d 'Show, enable, or disable shared mode'
complete -c gits -f -n __gits_no_subcommand -a list -d 'Show submodules and shared repository state'
complete -c gits -f -n __gits_no_subcommand -a clean -d 'Preview or remove unused shared mirrors'
complete -c gits -f -n __gits_no_subcommand -a 'status update deinit foreach summary sync set-branch set-url absorbgitdirs' -d 'Pass through to git submodule'
complete -c gits -f -n __gits_no_subcommand -a help -d 'Show help'
complete -c gits -n __gits_no_subcommand -s h -l help -d 'Show help'
complete -c gits -n __gits_no_subcommand -s v -l version -d 'Show the installed version'

complete -c gits -n '__fish_seen_subcommand_from admit' -l all -d 'Stage every declared submodule'
complete -c gits -F -n '__fish_seen_subcommand_from admit'

complete -c gits -n '__fish_seen_subcommand_from pull' -l all -d 'Update every declared submodule'
complete -c gits -F -n '__fish_seen_subcommand_from pull'

complete -c gits -n '__fish_seen_subcommand_from clean' -l scan -r -a '(__fish_complete_directories)' -d 'Register a project scan root'
complete -c gits -n '__fish_seen_subcommand_from clean' -l apply -d 'Delete mirrors unused for at least 30 days'
complete -c gits -n '__fish_seen_subcommand_from clean' -l forget-scan -r -a '(__fish_complete_directories)' -d 'Remove a registered scan root'

complete -c gits -n '__fish_seen_subcommand_from reset' -l hard -d 'Discard working tree changes'
complete -c gits -n '__fish_seen_subcommand_from reset' -l all -d 'Reset the repository and every declared submodule'
complete -c gits -F -n '__fish_seen_subcommand_from reset'
complete -c gits -n '__fish_seen_subcommand_from config' -l unset -d 'Disable shared mode'
complete -c gits -F -n '__fish_seen_subcommand_from config init'

complete -c gits -n '__fish_seen_subcommand_from add' -s q -l quiet -d 'Suppress progress output'
complete -c gits -n '__fish_seen_subcommand_from add' -s b -l branch -r -d 'Checkout branch'
complete -c gits -n '__fish_seen_subcommand_from add' -s f -l force -d 'Allow an otherwise ignored path'
complete -c gits -n '__fish_seen_subcommand_from add' -l name -r -d 'Set the submodule name'
complete -c gits -n '__fish_seen_subcommand_from add' -l reference -r -a '(__fish_complete_directories)' -d 'Reference repository'
complete -c gits -n '__fish_seen_subcommand_from add' -l dissociate -d 'Borrow objects only during clone'
complete -c gits -n '__fish_seen_subcommand_from add' -l depth -r -d 'Create a shallow clone'
complete -c gits -n '__fish_seen_subcommand_from add' -l progress -d 'Force progress reporting'
complete -c gits -n '__fish_seen_subcommand_from add' -l no-progress -d 'Disable progress reporting'
complete -c gits -F -n '__fish_seen_subcommand_from add'

EOF
            ;;
        *)
            error "unsupported completion shell '$1'; expected bash, zsh, or fish"
            return 1
            ;;
    esac
}

shared_base() {
    local root="$1"
    git -C "$root" config --local --get "$CONFIG_KEY" 2>/dev/null
}

canonical_directory() {
    local path="$1"

    mkdir -p "$path" || return 1
    (
        cd "$path" || exit 1
        pwd -P
    )
}

canonical_existing_directory() {
    local path="$1"

    [ -d "$path" ] || return 1
    (
        cd "$path" || exit 1
        pwd -P
    )
}

acquire_shared_lock() {
    local base="$1"
    local lock="$base/.gits/lock"
    local owner

    mkdir -p "$base/.gits" || return 1
    if ! mkdir "$lock" 2>/dev/null; then
        owner=$(sed -n '1p' "$lock/pid" 2>/dev/null)
        if [ -n "$owner" ]; then
            error "shared modules repository is locked by process $owner: $lock"
        else
            error "shared modules repository is locked: $lock"
        fi
        return 1
    fi
    printf '%s\n' "$$" > "$lock/pid" || {
        rmdir "$lock" 2>/dev/null || true
        return 1
    }
    SHARED_LOCK_DIR="$lock"
}

release_shared_lock() {
    [ -n "$SHARED_LOCK_DIR" ] || return 0
    rm -f "$SHARED_LOCK_DIR/pid"
    rmdir "$SHARED_LOCK_DIR" 2>/dev/null || true
    SHARED_LOCK_DIR=""
}

run_with_shared_lock() {
    local base="$1"
    local status
    shift

    acquire_shared_lock "$base" || return 1
    "$@"
    status=$?
    release_shared_lock
    return "$status"
}

enable_shared() {
    local root="$1"
    local requested_path="$2"
    local path

    path=$(canonical_directory "$requested_path") || return 1
    git -C "$root" config --local "$CONFIG_KEY" "$path" || return 1
    printf 'shared modules repository enabled for this project: %s%s%s\n' "$GREEN" "$path" "$RESET"
}

disable_shared() {
    local root="$1"
    local key
    local path
    local name
    local url
    local mirror
    local legacy_mirror

    while IFS= read -r -d '' key && IFS= read -r -d '' path; do
        [ -n "$key" ] || continue
        git -C "$root/$path" rev-parse --git-dir >/dev/null 2>&1 || continue
        name=${key#submodule.}
        name=${name%.path}
        url=$(git -C "$root" config --local --get "submodule.$name.url" 2>/dev/null)
        [ -n "$url" ] || url=$(git config --file "$root/.gitmodules" --get "submodule.$name.url" 2>/dev/null)
        [ -n "$url" ] || continue
        mirror=$(mirror_path "." "$url") || return 1
        legacy_mirror=$(legacy_mirror_path "." "$url") || return 1
        remove_alternate "$root/$path" "$mirror" "$legacy_mirror" || return 1
        attach_submodule_branch "$root" "$path" "$name" || return 1
    done < <(submodule_entries "$root")
    git -C "$root" config --local --unset-all "$CONFIG_KEY" 2>/dev/null || true
    printf 'shared modules repository for this project: %sDisabled%s\n' "$RED" "$RESET"
}

submodule_entries() {
    local root="$1"
    local entry
    local key
    local path

    [ -f "$root/.gitmodules" ] || return 0
    while IFS= read -r -d '' entry; do
        key=${entry%%$'\n'*}
        path=${entry#*$'\n'}
        printf '%s\0%s\0' "$key" "$path"
    done < <(git config -z --file "$root/.gitmodules" --get-regexp 'submodule\..*\.path' 2>/dev/null)
}

normal_init() {
    local root="$1"
    local key
    local path
    local name

    print_cmd "git submodule sync --recursive"
    git -C "$root" submodule sync --recursive || return 1
    # print_cmd "git submodule update --init --recursive"
    git -C "$root" submodule update --init --recursive || return 1

    while IFS= read -r -d '' key && IFS= read -r -d '' path; do
        [ -n "$key" ] || continue
        name=${key#submodule.}
        name=${name%.path}
        attach_submodule_branch "$root" "$path" "$name" || return 1
    done < <(submodule_entries "$root")
}

normal_pull() {
    local root="$1"
    shift
    local key
    local path
    local name

    print_cmd "git pull --ff-only"
    git -C "$root" pull --ff-only || return 1
    validate_submodule_paths "$root" "$@" || return 1
    # print_cmd "git submodule sync --recursive"
    git -C "$root" submodule sync --recursive || return 1

    while IFS= read -r -d '' key && IFS= read -r -d '' path; do
        [ -n "$key" ] || continue
        submodule_path_selected "$path" "$@" || continue
        name=${key#submodule.}
        name=${name%.path}
        print_cmd "git submodule update --init -- $path"
        git -C "$root" submodule update --init -- "$path" || return 1
        attach_submodule_branch "$root" "$path" "$name" || return 1
        # print_cmd "git submodule update --init --remote --merge -- $path"
        git -C "$root" submodule update --init --remote --merge -- "$path" || return 1
        # print_cmd "git -C $path submodule update --init --recursive"
        git -C "$root/$path" submodule update --init --recursive || return 1
    done < <(submodule_entries "$root")
}

mirror_url_key() {
    local url="$1"

    printf '%s\n' "${url%.git}"
}

mirror_path_for_key() {
    local base="$1"
    local key="$2"
    local hash
    local slug

    hash=$(printf '%s' "$key" | git hash-object --stdin) || return 1
    slug=$(basename "${key%.git}")
    slug=$(printf '%s' "$slug" | tr -c '[:alnum:]._- ' '_' | tr ' ' '_')
    printf '%s/repositories/%s-%s.git\n' "$base" "$slug" "${hash:0:12}"
}

mirror_path() {
    local base="$1"
    local url="$2"
    local key

    key=$(mirror_url_key "$url") || return 1
    mirror_path_for_key "$base" "$key"
}

legacy_mirror_path() {
    local base="$1"
    local url="$2"
    local key

    key=$(mirror_url_key "$url") || return 1
    mirror_path_for_key "$base" "$key.git"
}

update_mirror() {
    local url="$1"
    local mirror="$2"

    mkdir -p "$(dirname "$mirror")" || return 1
    if [ -e "$mirror" ]; then
        if [ "$(git -C "$mirror" rev-parse --is-bare-repository 2>/dev/null)" != "true" ]; then
            error "shared modules repository path is not a bare Git repository: $mirror"
            return 1
        fi
        # print_cmd "git -C $mirror remote update --prune"
        git -C "$mirror" remote update --prune
    else
        print_cmd "git clone --mirror $url $mirror"
        git clone --mirror "$url" "$mirror"
    fi
}

add_alternate() {
    local checkout="$1"
    local mirror="$2"
    local legacy_mirror="${3:-$mirror}"
    local alternates
    local alternate
    local mirror_name
    local legacy_mirror_name
    local objects="$mirror/objects"
    local found=false
    local temp

    alternates=$(git -C "$checkout" rev-parse --path-format=absolute --git-path objects/info/alternates 2>/dev/null) || return 1
    mkdir -p "$(dirname "$alternates")" || return 1
    mirror_name=$(basename "$mirror")
    legacy_mirror_name=$(basename "$legacy_mirror")
    temp="$alternates.gits.$$"
    : > "$temp" || return 1

    if [ -f "$alternates" ]; then
        while IFS= read -r alternate || [ -n "$alternate" ]; do
            case "$alternate" in
                "$objects")
                    if [ "$found" != "true" ]; then
                        printf '%s\n' "$alternate" >> "$temp" || return 1
                        found=true
                    fi
                    ;;
                */repositories/"$mirror_name"/objects|*/repositories/"$legacy_mirror_name"/objects)
                    ;;
                *)
                    printf '%s\n' "$alternate" >> "$temp" || return 1
                    ;;
            esac
        done < "$alternates"
    fi
    if [ "$found" != "true" ]; then
        printf '%s\n' "$objects" >> "$temp" || return 1
    fi
    mv "$temp" "$alternates"
}

remove_alternate() {
    local checkout="$1"
    local mirror="$2"
    local legacy_mirror="${3:-$mirror}"
    local alternates
    local alternate
    local mirror_name
    local legacy_mirror_name
    local temp

    alternates=$(git -C "$checkout" rev-parse --path-format=absolute --git-path objects/info/alternates 2>/dev/null) || return 1
    [ -f "$alternates" ] || return 0
    mirror_name=$(basename "$mirror")
    legacy_mirror_name=$(basename "$legacy_mirror")
    temp="$alternates.gits.$$"
    : > "$temp" || return 1

    while IFS= read -r alternate || [ -n "$alternate" ]; do
        case "$alternate" in
            */repositories/"$mirror_name"/objects|*/repositories/"$legacy_mirror_name"/objects)
                ;;
            *)
                printf '%s\n' "$alternate" >> "$temp" || return 1
                ;;
        esac
    done < "$alternates"

    if [ -s "$temp" ]; then
        mv "$temp" "$alternates"
    else
        rm -f "$temp" "$alternates"
    fi
}

submodule_branch() {
    local root="$1"
    local name="$2"
    local checkout="$3"
    local mirror="${4:-}"
    local branch

    branch=$(git config --file "$root/.gitmodules" --get "submodule.$name.branch" 2>/dev/null)
    if [ "$branch" = "." ]; then
        branch=$(git -C "$root" symbolic-ref --short -q HEAD)
    fi
    if [ -z "$branch" ] && [ -n "$mirror" ]; then
        branch=$(git -C "$mirror" symbolic-ref --short -q HEAD)
    fi
    [ -n "$branch" ] || branch=$(git -C "$checkout" symbolic-ref --short -q refs/remotes/origin/HEAD)
    branch=${branch#refs/heads/}
    branch=${branch#refs/remotes/origin/}
    branch=${branch#origin/}
    printf '%s\n' "$branch"
}

attach_submodule_branch() {
    local root="$1"
    local path="$2"
    local name="$3"
    local mirror="${4:-}"
    local checkout="$root/$path"
    local branch

    if git -C "$checkout" symbolic-ref --short -q HEAD >/dev/null; then
        return 0
    fi

    branch=$(submodule_branch "$root" "$name" "$checkout" "$mirror")
    if [ -z "$branch" ]; then
        error "cannot determine remote branch for submodule: $path"
        return 1
    fi

    if git -C "$checkout" show-ref --verify --quiet "refs/heads/$branch"; then
        if git -C "$checkout" show-ref --verify --quiet "refs/remotes/origin/$branch" &&
            git -C "$checkout" merge-base --is-ancestor "refs/heads/$branch" "refs/remotes/origin/$branch"; then
            # print_cmd "git -C $path branch -f $branch HEAD"
            git -C "$checkout" branch -f "$branch" HEAD || return 1
        fi
        # print_cmd "git -C $path checkout $branch"
        git -C "$checkout" checkout "$branch" || return 1
    else
        # print_cmd "git -C $path checkout -b $branch"
        git -C "$checkout" checkout -b "$branch" || return 1
    fi

    if git -C "$checkout" show-ref --verify --quiet "refs/remotes/origin/$branch"; then
        git -C "$checkout" branch --set-upstream-to="origin/$branch" "$branch" >/dev/null || return 1
    fi
}

update_checkout_from_mirror() {
    local root="$1"
    local path="$2"
    local name="$3"
    local mirror="$4"
    local checkout="$root/$path"
    local branch

    branch=$(submodule_branch "$root" "$name" "$checkout" "$mirror")
    if [ -z "$branch" ] || ! git -C "$mirror" show-ref --verify --quiet "refs/heads/$branch"; then
        error "cannot determine remote branch for submodule: $path"
        return 1
    fi

    print_cmd "git -C $path fetch $mirror $branch"
    git -C "$checkout" fetch "$mirror" "+refs/heads/$branch:refs/remotes/origin/$branch" || return 1
    if git -C "$checkout" show-ref --verify --quiet "refs/heads/$branch"; then
        # print_cmd "git -C $path checkout $branch"
        git -C "$checkout" checkout "$branch" || return 1
    else
        # print_cmd "git -C $path checkout -b $branch origin/$branch"
        git -C "$checkout" checkout -b "$branch" "refs/remotes/origin/$branch" || return 1
    fi
    # print_cmd "git -C $path merge --ff-only origin/$branch"
    git -C "$checkout" merge --ff-only "refs/remotes/origin/$branch"
}

shared_update() {
    local root="$1"
    local base="$2"
    local update_remote="${3:-false}"
    if [ "$#" -ge 3 ]; then
        shift 3
    else
        shift 2
    fi
    local key
    local path
    local name
    local url
    local mirror
    local legacy_mirror
    local updated_mirror
    local mirror_is_updated
    local -a updated_mirrors=()

    printf 'using shared modules repository: %s%s%s\n' "$GREEN" "$base" "$RESET"
    print_cmd "git submodule sync --recursive"
    git -C "$root" submodule sync --recursive || return 1

    while IFS= read -r -d '' key && IFS= read -r -d '' path; do
        [ -n "$key" ] || continue
        submodule_path_selected "$path" "$@" || continue
        name=${key#submodule.}
        name=${name%.path}

        git -C "$root" submodule init -- "$path" >/dev/null || return 1
        url=$(git -C "$root" config --local --get "submodule.$name.url")
        if [ -z "$url" ]; then
            error "missing submodule URL: $path"
            return 1
        fi

        mirror=$(mirror_path "$base" "$url") || return 1
        legacy_mirror=$(legacy_mirror_path "$base" "$url") || return 1
        mirror_is_updated=false
        for updated_mirror in "${updated_mirrors[@]}"; do
            if [ "$updated_mirror" = "$mirror" ]; then
                mirror_is_updated=true
                break
            fi
        done
        if [ "$mirror_is_updated" != "true" ]; then
            update_mirror "$url" "$mirror" || return 1
            updated_mirrors+=("$mirror")
        fi

        if [ -e "$root/$path/.git" ]; then
            add_alternate "$root/$path" "$mirror" "$legacy_mirror" || return 1
            if [ "$update_remote" != "true" ]; then
                print_cmd "git submodule update --init -- $path"
                git -C "$root" submodule update --init -- "$path" || return 1
            fi
        else
            print_cmd "git submodule update --init --reference -- $path"
            git -C "$root" submodule update --init --reference "$mirror" -- "$path" || return 1
            add_alternate "$root/$path" "$mirror" "$legacy_mirror" || return 1
        fi

        if [ "$update_remote" = "true" ]; then
            update_checkout_from_mirror "$root" "$path" "$name" "$mirror" || return 1
        else
            attach_submodule_branch "$root" "$path" "$name" "$mirror" || return 1
        fi
        # print_cmd "git -C $path submodule update --init --recursive"
        git -C "$root/$path" submodule update --init --recursive || return 1
    done < <(submodule_entries "$root")
}

shared_pull() {
    local root="$1"
    local base="$2"
    shift 2

    # print_cmd "git -c fetch.recurseSubmodules=false pull --ff-only"
    git -C "$root" -c fetch.recurseSubmodules=false pull --ff-only || return 1
    validate_submodule_paths "$root" "$@" || return 1
    shared_update "$root" "$base" true "$@"
}

reset_repository() {
    local root="$1"
    local mode="$2"
    shift 2
    local key
    local path
    local name
    local requested
    local -a paths=()

    validate_submodule_paths "$root" "$@" || return 1
    for requested in "$@"; do
        paths+=("$(normalize_submodule_path "$requested")")
    done

    if [ "$mode" = "--hard" ]; then
        if [ "${#paths[@]}" -gt 0 ]; then
            print_cmd "git reset -- ${paths[*]}"
            git -C "$root" reset -- "${paths[@]}" || return 1
            for path in "${paths[@]}"; do
                [ -e "$root/$path/.git" ] || continue
                print_cmd "git -C $path reset --hard"
                git -C "$root/$path" reset --hard || return 1
                git -C "$root/$path" submodule foreach --recursive git reset --hard || return 1
            done
            print_cmd "git submodule update --init --recursive --force -- ${paths[*]}"
            git -C "$root" submodule update --init --recursive --force -- "${paths[@]}" || return 1
        else
            print_cmd "git reset --hard"
            git -C "$root" reset --hard || return 1
            print_cmd "git submodule foreach --recursive git reset --hard"
            git -C "$root" submodule foreach --recursive git reset --hard || return 1
            # print_cmd "git submodule update --init --recursive --force"
            git -C "$root" submodule update --init --recursive --force || return 1
        fi
    else
        if [ "${#paths[@]}" -gt 0 ]; then
            print_cmd "git reset -- ${paths[*]}"
            git -C "$root" reset -- "${paths[@]}" || return 1
            for path in "${paths[@]}"; do
                [ -e "$root/$path/.git" ] || continue
                print_cmd "git -C $path reset"
                git -C "$root/$path" reset || return 1
                git -C "$root/$path" submodule foreach --recursive git reset || return 1
            done
        else
            print_cmd "git reset"
            git -C "$root" reset || return 1
            print_cmd "git submodule foreach --recursive git reset"
            git -C "$root" submodule foreach --recursive git reset || return 1
        fi
    fi

    while IFS= read -r -d '' key && IFS= read -r -d '' path; do
        [ -n "$key" ] || continue
        submodule_path_selected "$path" "$@" || continue
        [ -e "$root/$path/.git" ] || continue
        name=${key#submodule.}
        name=${name%.path}
        attach_submodule_branch "$root" "$path" "$name" || return 1
    done < <(submodule_entries "$root")

    git -C "$root" status --short
}

is_submodule_path() {
    local root="$1"
    local candidate="$2"
    local key
    local path

    while IFS= read -r -d '' key && IFS= read -r -d '' path; do
        [ "$path" = "$candidate" ] && return 0
    done < <(submodule_entries "$root")
    return 1
}

normalize_submodule_path() {
    local candidate="$1"

    while [ "$candidate" != "/" ] && [ "${candidate%/}" != "$candidate" ]; do
        candidate=${candidate%/}
    done
    printf '%s\n' "$candidate"
}

validate_submodule_paths() {
    local root="$1"
    local requested
    local candidate
    shift

    for requested in "$@"; do
        candidate=$(normalize_submodule_path "$requested")
        if ! is_submodule_path "$root" "$candidate"; then
            error "unknown submodule path: $requested"
            return 1
        fi
    done
}

submodule_path_selected() {
    local path="$1"
    local requested
    shift

    [ "$#" -gt 0 ] || return 0
    for requested in "$@"; do
        if [ "$path" = "$(normalize_submodule_path "$requested")" ]; then
            return 0
        fi
    done
    return 1
}

normalize_add_path() {
    local root="$1"
    local requested="$2"
    local candidate="$requested"

    while [ "$candidate" != "/" ] && [ "${candidate%/}" != "$candidate" ]; do
        candidate=${candidate%/}
    done

    if is_submodule_path "$root" "$candidate"; then
        printf '%s\n' "$candidate"
    else
        printf '%s\n' "$requested"
    fi
}

restore_index() {
    local index_path="$1"
    local backup="$2"
    local had_index="$3"

    if [ "$had_index" = "true" ]; then
        cp "$backup" "$index_path"
    else
        rm -f "$index_path"
    fi
}

default_commit_message() {
    local root="$1"
    local path
    local key
    local submodule_path
    local is_submodule
    local has_non_submodule=false
    local joined=""
    local -a staged_paths=()
    local -a staged_submodules=()

    while IFS= read -r -d '' path; do
        staged_paths+=("$path")
    done < <(git -C "$root" diff --cached --name-only -z)

    [ "${#staged_paths[@]}" -gt 0 ] || return 1

    for path in "${staged_paths[@]}"; do
        is_submodule=false
        while IFS= read -r -d '' key && IFS= read -r -d '' submodule_path; do
            if [ "$path" = "$submodule_path" ]; then
                is_submodule=true
                break
            fi
        done < <(submodule_entries "$root")

        if [ "$is_submodule" != "true" ]; then
            has_non_submodule=true
        fi
    done

    while IFS= read -r -d '' key && IFS= read -r -d '' submodule_path; do
        for path in "${staged_paths[@]}"; do
            if [ "$path" = "$submodule_path" ]; then
                staged_submodules+=("$path")
                break
            fi
        done
    done < <(submodule_entries "$root")

    if [ "$has_non_submodule" = "true" ]; then
        printf 'feat:\n'
        return 0
    fi

    for path in "${staged_submodules[@]}"; do
        if [ -n "$joined" ]; then
            joined="$joined $path"
        else
            joined="$path"
        fi
    done
    printf 'update submodule: %s\n' "$joined"
}

admit_paths() {
    local root="$1"
    shift
    local index_path
    local backup
    local had_index=false
    local before_tree
    local after_tree
    local default_message
    local status
    local key
    local path
    local requested
    local -a paths=()

    [ "$#" -gt 0 ] || {
        error "admit requires at least one path or --all"
        return 1
    }

    if [ "$1" = "--all" ]; then
        [ "$#" -eq 1 ] || {
            error "admit --all accepts no additional paths"
            return 1
        }
        while IFS= read -r -d '' key && IFS= read -r -d '' path; do
            paths+=("$path")
        done < <(submodule_entries "$root")
        [ "${#paths[@]}" -gt 0 ] || {
            error "no submodules found"
            return 1
        }
    else
        for requested in "$@"; do
            [ "${requested#-}" = "$requested" ] || {
                error "admit supports paths or --all"
                return 1
            }
            paths+=("$(normalize_add_path "$root" "$requested")")
        done
    fi

    index_path=$(git -C "$root" rev-parse --path-format=absolute --git-path index) || return 1
    backup=$(mktemp "${TMPDIR:-/tmp}/gits-index.XXXXXX") || return 1
    if [ -f "$index_path" ]; then
        cp "$index_path" "$backup" || {
            rm -f "$backup"
            return 1
        }
        had_index=true
    fi
    before_tree=$(git -C "$root" write-tree) || {
        rm -f "$backup"
        return 1
    }

    trap 'restore_index "$index_path" "$backup" "$had_index"; rm -f "$backup"; error "admit cancelled; index restored"; trap - INT TERM HUP; exit 130' INT TERM HUP

    print_cmd "git add -- ${paths[*]}"
    git -C "$root" add -- "${paths[@]}" || {
        status=$?
        restore_index "$index_path" "$backup" "$had_index"
        rm -f "$backup"
        trap - INT TERM HUP
        return "$status"
    }

    after_tree=$(git -C "$root" write-tree) || {
        restore_index "$index_path" "$backup" "$had_index"
        rm -f "$backup"
        trap - INT TERM HUP
        return 1
    }
    if [ "$before_tree" = "$after_tree" ]; then
        rm -f "$backup"
        trap - INT TERM HUP
        error "no changes added"
        return 1
    fi

    default_message=$(default_commit_message "$root") || {
        restore_index "$index_path" "$backup" "$had_index"
        rm -f "$backup"
        trap - INT TERM HUP
        error "no staged changes to commit"
        return 1
    }

    echo "default commit message: $default_message"
    git -C "$root" commit --edit -m "$default_message" || {
        status=$?
        restore_index "$index_path" "$backup" "$had_index"
        rm -f "$backup"
        trap - INT TERM HUP
        error "admit cancelled; index restored"
        return "$status"
    }

    rm -f "$backup"
    trap - INT TERM HUP
}

list_submodules() {
    local root="$1"
    local base="$2"
    local key
    local path
    local name
    local declared_url
    local resolved_url
    local mirror
    local state

    if [ -n "$base" ]; then
        printf 'shared modules repository: %s%s%s\n' "$GREEN" "$base" "$RESET"
    else
        printf 'shared modules repository: %sdisabled%s\n' "$RED" "$RESET"
    fi

    if [ ! -f "$root/.gitmodules" ]; then
        echo "no submodules"
        return 0
    fi

    while IFS= read -r -d '' key && IFS= read -r -d '' path; do
        [ -n "$key" ] || continue
        name=${key#submodule.}
        name=${name%.path}
        declared_url=$(git config --file "$root/.gitmodules" --get "submodule.$name.url")
        printf '%s%s%s : %s' "$GREEN" "$path" "$RESET" "$declared_url"
        if [ -n "$base" ]; then
            resolved_url=$(git -C "$root" config --local --get "submodule.$name.url" 2>/dev/null)
            [ -n "$resolved_url" ] || resolved_url="$declared_url"
            mirror=$(mirror_path "$base" "$resolved_url") || return 1
            state="not cached"
            [ -d "$mirror" ] && state="cached"
            printf ' -> %s (%s)\n' "$mirror" "$state"
        else
            printf '\n'
        fi
    done < <(submodule_entries "$root")
}

clean_state_file() {
    local base="$1"

    printf '%s/.gits/clean-config\n' "$base"
}

register_clean_scan_root() {
    local base="$1"
    local requested="$2"
    local root
    local state
    local existing

    root=$(canonical_existing_directory "$requested") || {
        error "clean scan root does not exist or is not readable: $requested"
        return 1
    }
    state=$(clean_state_file "$base")
    while IFS= read -r existing; do
        if [ "$existing" = "$root" ]; then
            printf 'clean scan root already registered: %s\n' "$root"
            return 0
        fi
    done < <(git config --file "$state" --get-all clean.scanRoot 2>/dev/null)
    git config --file "$state" --add clean.scanRoot "$root" || return 1
    printf 'clean scan root registered: %s%s%s\n' "$GREEN" "$root" "$RESET"
}

forget_clean_scan_root() {
    local base="$1"
    local requested="$2"
    local root="$requested"
    local state
    local existing
    local found=false

    if [ -d "$requested" ]; then
        root=$(canonical_existing_directory "$requested") || return 1
    elif [ "${requested#/}" = "$requested" ]; then
        root="$PWD/$requested"
    fi
    state=$(clean_state_file "$base")
    while IFS= read -r existing; do
        if [ "$existing" = "$root" ]; then
            found=true
            break
        fi
    done < <(git config --file "$state" --get-all clean.scanRoot 2>/dev/null)
    if [ "$found" != "true" ]; then
        error "clean scan root is not registered: $root"
        return 1
    fi
    git config --file "$state" --fixed-value --unset-all clean.scanRoot "$root" || return 1
    printf 'clean scan root forgotten: %s%s%s\n' "$YELLOW" "$root" "$RESET"
    printf 'no mirrors were deleted\n'
}

clean_candidate_key() {
    local mirror="$1"

    printf '%s' "$mirror" | git hash-object --stdin
}

format_size_kb() {
    local size_kb="$1"

    awk -v size="$size_kb" 'BEGIN {
        if (size >= 1048576) {
            printf "%.1f GiB", size / 1048576
        } else if (size >= 1024) {
            printf "%.1f MiB", size / 1024
        } else {
            printf "%d KiB", size
        }
    }'
}

scan_and_clean_mirrors() {
    local base="$1"
    local apply="$2"
    local state
    local last_scan_file="$base/.gits/last-scan"
    local repo_dir="$base/repositories"
    local temp
    local roots_file
    local alternates_file
    local mirrors_file
    local eligible_file
    local root
    local entry
    local mirror
    local mirror_name
    local objects
    local size_kb
    local key
    local alternates
    local object_db
    local alternate
    local resolved
    local mirror_key
    local mirror_path_value
    local mirror_objects
    local mirror_size
    local consumer_file
    local consumer_count
    local consumer
    local first_unused
    local now
    local age_seconds
    local age_days
    local remaining_days
    local human_size
    local blocked=false
    local used_count=0
    local waiting_count=0
    local eligible_count=0
    local eligible_kb=0
    local deleted_count=0
    local deleted_kb=0

    state=$(clean_state_file "$base")
    temp=$(mktemp -d "${TMPDIR:-/tmp}/gits-clean.XXXXXX") || return 1
    roots_file="$temp/roots"
    alternates_file="$temp/alternates"
    mirrors_file="$temp/mirrors"
    eligible_file="$temp/eligible"
    mkdir "$temp/consumers" || {
        rm -rf "$temp"
        return 1
    }
    : > "$alternates_file"
    : > "$mirrors_file"
    : > "$eligible_file"
    : > "$temp/last-scan"
    git config --file "$state" --get-all clean.scanRoot > "$roots_file" 2>/dev/null || true

    printf 'shared modules repository: %s%s%s\n' "$GREEN" "$base" "$RESET"
    if [ ! -s "$roots_file" ]; then
        rm -rf "$temp"
        error "no clean scan roots registered; use 'gits clean --scan <root>' first"
        return 1
    fi
    printf 'scan roots:\n'
    while IFS= read -r root; do
        printf '  %s%s%s\n' "$GREEN" "$root" "$RESET"
        if [ ! -d "$root" ] || [ ! -r "$root" ]; then
            error "clean scan root is unavailable: $root"
            blocked=true
            continue
        fi
        if ! find "$root" -type f -path '*/objects/info/alternates' -print0 >> "$alternates_file" 2> "$temp/find-errors"; then
            error "failed to scan clean root: $root"
            sed -n '1,5p' "$temp/find-errors" >&2
            blocked=true
        fi
    done < "$roots_file"

    if [ -L "$repo_dir" ] || { [ -e "$repo_dir" ] && [ ! -d "$repo_dir" ]; }; then
        error "blocked invalid shared repositories directory: $repo_dir"
        blocked=true
    elif [ -d "$repo_dir" ]; then
        for entry in "$repo_dir"/.[!.]* "$repo_dir"/..?*; do
            [ -e "$entry" ] || continue
            error "blocked unexpected entry in shared repositories: $entry"
            blocked=true
        done
        for entry in "$repo_dir"/*; do
            [ -e "$entry" ] || continue
            mirror_name=$(basename "$entry")
            if [ -L "$entry" ]; then
                error "blocked symbolic link in shared repositories: $entry"
                blocked=true
                continue
            fi
            case "$mirror_name" in
                *.git)
                    ;;
                *)
                    error "blocked unexpected entry in shared repositories: $entry"
                    blocked=true
                    continue
                    ;;
            esac
            if [ ! -d "$entry" ] || [ "$(git -C "$entry" rev-parse --is-bare-repository 2>/dev/null)" != "true" ]; then
                error "blocked non-bare shared mirror: $entry"
                blocked=true
                continue
            fi
            mirror=$(canonical_existing_directory "$entry") || {
                error "cannot resolve shared mirror: $entry"
                blocked=true
                continue
            }
            if [ -L "$mirror/objects" ]; then
                error "blocked symbolic link for shared mirror objects: $mirror/objects"
                blocked=true
                continue
            fi
            objects=$(canonical_existing_directory "$mirror/objects") || {
                error "cannot resolve shared mirror objects: $mirror"
                blocked=true
                continue
            }
            size_kb=$(du -sk "$mirror" 2>/dev/null | awk '{print $1}')
            if [ -z "$size_kb" ]; then
                error "cannot measure shared mirror: $mirror"
                blocked=true
                continue
            fi
            key=$(clean_candidate_key "$mirror") || {
                blocked=true
                continue
            }
            : > "$temp/consumers/$key"
            printf '%s\t%s\t%s\t%s\n' "$key" "$mirror" "$objects" "$size_kb" >> "$mirrors_file"
        done
    fi

    while IFS= read -r -d '' alternates; do
        object_db=${alternates%/info/alternates}
        while IFS= read -r alternate || [ -n "$alternate" ]; do
            [ -n "$alternate" ] || continue
            case "$alternate" in
                /*)
                    resolved=$(canonical_existing_directory "$alternate" 2>/dev/null)
                    ;;
                *)
                    resolved=$(canonical_existing_directory "$object_db/$alternate" 2>/dev/null)
                    ;;
            esac
            if [ -z "$resolved" ]; then
                error "blocked invalid alternate in $alternates: $alternate"
                blocked=true
                continue
            fi
            while IFS=$'\t' read -r mirror_key mirror_path_value mirror_objects mirror_size; do
                if [ "$resolved" = "$mirror_objects" ]; then
                    printf '%s\n' "$alternates" >> "$temp/consumers/$mirror_key"
                    break
                fi
            done < "$mirrors_file"
        done < "$alternates"
    done < "$alternates_file"

    if [ "$blocked" = "true" ]; then
        printf 'blocked: clean scan is incomplete; no candidate state or mirrors were changed\n' >&2
        rm -rf "$temp"
        return 1
    fi

    now=$(date +%s)
    while IFS=$'\t' read -r mirror_key mirror_path_value mirror_objects mirror_size; do
        consumer_file="$temp/consumers/$mirror_key"
        consumer_count=$(wc -l < "$consumer_file" | tr -d ' ')
        human_size=$(format_size_kb "$mirror_size")
        if [ "$consumer_count" -gt 0 ]; then
            git config --file "$state" --remove-section "candidate.$mirror_key" 2>/dev/null || true
            printf '%s\tused\t%s\t%s\t%s\n' "$now" "$mirror_size" "$consumer_count" "$mirror_path_value" >> "$temp/last-scan"
            printf 'used: %s%s%s (%s, %s consumers)\n' "$GREEN" "$(basename "$mirror_path_value")" "$RESET" "$human_size" "$consumer_count"
            while IFS= read -r consumer; do
                printf '  %s\n' "$consumer"
            done < "$consumer_file"
            used_count=$((used_count + 1))
            continue
        fi

        first_unused=$(git config --file "$state" --get "candidate.$mirror_key.firstUnused" 2>/dev/null)
        case "$first_unused" in
            ""|*[!0-9]*)
                first_unused="$now"
                git config --file "$state" "candidate.$mirror_key.firstUnused" "$first_unused" || {
                    rm -rf "$temp"
                    return 1
                }
                git config --file "$state" "candidate.$mirror_key.mirror" "$mirror_path_value" || {
                    rm -rf "$temp"
                    return 1
                }
                ;;
        esac
        age_seconds=$((now - first_unused))
        [ "$age_seconds" -ge 0 ] || age_seconds=0
        age_days=$((age_seconds / 86400))
        if [ "$age_seconds" -ge "$CLEAN_GRACE_SECONDS" ]; then
            printf '%s\teligible\t%s\t0\t%s\n' "$now" "$mirror_size" "$mirror_path_value" >> "$temp/last-scan"
            printf 'eligible: %s%s%s (%s, unused %s days)\n' "$RED" "$(basename "$mirror_path_value")" "$RESET" "$human_size" "$age_days"
            printf '%s\t%s\t%s\n' "$mirror_key" "$mirror_path_value" "$mirror_size" >> "$eligible_file"
            eligible_count=$((eligible_count + 1))
            eligible_kb=$((eligible_kb + mirror_size))
        else
            remaining_days=$(((CLEAN_GRACE_SECONDS - age_seconds + 86399) / 86400))
            printf '%s\twaiting\t%s\t0\t%s\n' "$now" "$mirror_size" "$mirror_path_value" >> "$temp/last-scan"
            printf 'waiting: %s%s%s (%s, unused %s days, %s days remaining)\n' "$YELLOW" "$(basename "$mirror_path_value")" "$RESET" "$human_size" "$age_days" "$remaining_days"
            waiting_count=$((waiting_count + 1))
        fi
    done < "$mirrors_file"

    mv "$temp/last-scan" "$last_scan_file" || {
        rm -rf "$temp"
        return 1
    }

    printf 'summary: %s used, %s waiting, %s eligible, %s reclaimable\n' "$used_count" "$waiting_count" "$eligible_count" "$(format_size_kb "$eligible_kb")"
    if [ "$apply" != "true" ]; then
        printf "dry run: use 'gits clean --apply' to delete eligible mirrors\n"
        rm -rf "$temp"
        return 0
    fi

    while IFS=$'\t' read -r mirror_key mirror_path_value mirror_size; do
        if [ "$(dirname "$mirror_path_value")" != "$repo_dir" ] || [ -L "$mirror_path_value" ] || [ -L "$mirror_path_value/objects" ] ||
            [ "$(git -C "$mirror_path_value" rev-parse --is-bare-repository 2>/dev/null)" != "true" ] ||
            [ -s "$temp/consumers/$mirror_key" ]; then
            error "mirror failed deletion validation: $mirror_path_value"
            rm -rf "$temp"
            return 1
        fi
    done < "$eligible_file"

    while IFS=$'\t' read -r mirror_key mirror_path_value mirror_size; do
        rm -rf "$mirror_path_value" || {
            error "failed to delete shared mirror: $mirror_path_value"
            rm -rf "$temp"
            return 1
        }
        git config --file "$state" --remove-section "candidate.$mirror_key" 2>/dev/null || true
        printf 'deleted: %s%s%s\n' "$GREEN" "$mirror_path_value" "$RESET"
        deleted_count=$((deleted_count + 1))
        deleted_kb=$((deleted_kb + mirror_size))
    done < "$eligible_file"
    printf 'cleaned: %s mirrors, %s reclaimed\n' "$deleted_count" "$(format_size_kb "$deleted_kb")"
    rm -rf "$temp"
}

clean_repository() {
    local base="$1"
    shift
    local mode="preview"
    local status=0
    local requested
    local -a scan_roots=()

    [ -d "$base" ] || {
        error "shared modules repository does not exist: $base"
        return 1
    }
    case "$1" in
        "")
            ;;
        --apply)
            [ "$#" -eq 1 ] || {
                error "clean --apply accepts no additional arguments"
                return 1
            }
            mode="apply"
            ;;
        --forget-scan)
            [ "$#" -eq 2 ] || {
                error "clean --forget-scan requires exactly one root"
                return 1
            }
            mode="forget"
            scan_roots+=("$2")
            ;;
        --scan)
            while [ "$#" -gt 0 ]; do
                [ "$1" = "--scan" ] && [ -n "$2" ] || {
                    error "clean accepts repeated --scan <root> arguments"
                    return 1
                }
                scan_roots+=("$2")
                shift 2
            done
            mode="scan"
            ;;
        *)
            error "clean accepts --scan <root>..., --apply, or --forget-scan <root>"
            return 1
            ;;
    esac

    acquire_shared_lock "$base" || return 1
    case "$mode" in
        scan)
            for requested in "${scan_roots[@]}"; do
                register_clean_scan_root "$base" "$requested" || {
                    status=1
                    break
                }
            done
            [ "$status" -ne 0 ] || scan_and_clean_mirrors "$base" false || status=$?
            ;;
        forget)
            forget_clean_scan_root "$base" "${scan_roots[0]}" || status=$?
            ;;
        apply)
            scan_and_clean_mirrors "$base" true || status=$?
            ;;
        *)
            scan_and_clean_mirrors "$base" false || status=$?
            ;;
    esac
    release_shared_lock
    return "$status"
}

main() {
    local root
    local base
    local mode

    case "$1" in
        help|--help|-h)
            usage
            return 0
            ;;
        --version|-v)
            echo "gits $VERSION"
            return 0
            ;;
        __completion)
            [ "$#" -eq 2 ] || {
                error "internal completion requires exactly one shell"
                return 1
            }
            completion_script "$2"
            return $?
            ;;
    esac

    require_git || return 1
    root=$(git_root) || {
        error "not a Git repository"
        return 1
    }

    case "$1" in
        init)
            if [ -n "$3" ]; then
                error "init accepts at most one shared_path"
                return 1
            fi
            if [ -n "$2" ]; then
                enable_shared "$root" "$2" || return 1
            fi
            base=$(shared_base "$root")
            if [ -n "$base" ]; then
                run_with_shared_lock "$base" shared_update "$root" "$base"
            else
                normal_init "$root"
            fi
            ;;
        pull)
            shift
            if [ "${1:-}" = "--all" ]; then
                [ "$#" -eq 1 ] || {
                    error "pull --all accepts no additional paths"
                    return 1
                }
                shift
            fi
            base=$(shared_base "$root")
            if [ -n "$base" ]; then
                run_with_shared_lock "$base" shared_pull "$root" "$base" "$@"
            else
                normal_pull "$root" "$@"
            fi
            ;;
        reset)
            shift
            mode=""
            if [ "${1:-}" = "--hard" ]; then
                mode="$1"
                shift
            fi
            if [ "${1:-}" = "--all" ]; then
                [ "$#" -eq 1 ] || {
                    error "reset --all accepts no additional paths"
                    return 1
                }
                shift
            fi
            reset_repository "$root" "$mode" "$@"
            ;;
        admit)
            shift
            admit_paths "$root" "$@"
            ;;
        config)
            [ -z "$3" ] || {
                error "config accepts at most one argument"
                return 1
            }
            case "$2" in
                --unset)
                    disable_shared "$root"
                    ;;
                "")
                    base=$(shared_base "$root")
                    if [ -n "$base" ]; then
                        echo "$base"
                    else
                        printf 'shared modules repository for this project: %sDisabled%s\n' "$RED" "$RESET"
                    fi
                    ;;
                *)
                    enable_shared "$root" "$2"
                    ;;
            esac
            ;;
        list|--list)
            [ -z "$2" ] || {
                error "list accepts no arguments"
                return 1
            }
            base=$(shared_base "$root")
            list_submodules "$root" "$base"
            ;;
        clean)
            base=$(shared_base "$root")
            [ -n "$base" ] || {
                error "clean requires shared mode for the current project"
                return 1
            }
            shift
            clean_repository "$base" "$@"
            ;;
        "")
            git -C "$root" submodule
            ;;
        *)
            git -C "$root" submodule "$@"
            ;;
    esac
}

main "$@"
